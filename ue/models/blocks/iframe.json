{
  "definitions": [
    {
      "title": "Iframe",
      "id": "iframe",
      "model": "iframe",
      "plugins": {
        "da": {
          "name": "iframe",
          "rows": 2,
          "columns": 1,
          "fields": [
            { "name": "title", "selector": "div:nth-child(1)>div" },
            { "name": "url", "selector": "div:nth-child(2)>div>p>a[href]" },
            { "name": "urlText", "selector": "div:nth-child(2)>div>p>a" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "iframe",
      "fields": [
        {
          "component": "select",
          "name": "classes",
          "label": "Mode",
          "description": "Use Launch link for sites that block iframe embedding (e.g. starhealth.in)",
          "options": [
            { "name": "Embed (iframe + open link)", "value": "" },
            { "name": "Launch link (opens in new tab)", "value": "link" },
            { "name": "Embed — short (400px)", "value": "h-400" },
            { "name": "Embed — medium (600px)", "value": "h-600" },
            { "name": "Embed — tall (800px)", "value": "h-800" },
            { "name": "Embed — extra tall (1000px)", "value": "h-1000" }
          ]
        },
        {
          "component": "text",
          "name": "title",
          "label": "Title",
          "valueType": "string",
          "description": "Optional heading (e.g. Find a Network Hospital)"
        },
        {
          "component": "text",
          "name": "urlText",
          "label": "Button / link label",
          "valueType": "string",
          "description": "Label for the open button (defaults to hostname if empty)"
        },
        {
          "component": "text",
          "name": "url",
          "label": "URL",
          "valueType": "string",
          "required": true,
          "description": "Page URL to embed or open"
        }
      ]
    }
  ],
  "filters": []
}
